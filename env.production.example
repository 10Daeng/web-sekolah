# ============================================
# SIST — Template Environment Variables untuk Laravel Cloud
# ============================================
# 
# CARA PENGISIAN:
# 1. Buka dashboard Laravel Cloud → Environment Variables
# 2. Copy semua isi file ini
# 3. Ganti semua tulisan BERWARNA MERAH (ISI_...) dengan value Anda sendiri
# 4. Paste ke Laravel Cloud
#
# ============================================

# ────────────────────────────────────────────
# 1. APP KEY (WAJIB — Generate dari lokal)
# ────────────────────────────────────────────
# CARA MENDAPATKAN:
#   Jalankan di terminal lokal Anda:
#     php artisan key:generate --show
#   Output contoh: base64:abc123...
#   Copy output tersebut ke bawah ini
APP_KEY=base64:ISI_DENGAN_KEY_ANDA

# ────────────────────────────────────────────
# 2. APP URL (WAJIB — Dari Laravel Cloud)
# ────────────────────────────────────────────
# CARA MENDAPATKAN:
#   Setelah project dibuat, Laravel Cloud akan berikan URL
#   Contoh: https://sist-a1b2c3.laravel.cloud
#   Atau jika pakai custom domain: https://sekolah.sch.id
APP_URL=https://ISI_URL_DARI_LARAVEL_CLOUD.laravel.cloud

APP_NAME=SIST
APP_ENV=production
APP_DEBUG=false

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

# ────────────────────────────────────────────
# 3. DATABASE — PostgreSQL (WAJIB)
# ────────────────────────────────────────────
# CARA MENDAPATKAN (Laravel Cloud Managed PostgreSQL):
#   1. Di dashboard Laravel Cloud → klik "Databases"
#   2. Klik "Create Database" → pilih PostgreSQL
#   3. Setelah database aktif, klik "Connection"
#   4. Copy nilai Host, Port, Database, Username, Password
#
# CARA MENDAPATKAN (Supabase):
#   1. Login https://supabase.com → buat project baru
#   2. Settings → Database → Connection String
#   3. Parse connection string ke format di bawah
#
# CARA MENDAPATKAN (Neon):
#   1. Login https://neon.tech → buat project
#   2. Copy connection parameters

DB_CONNECTION=pgsql
DB_HOST=ISI_DB_HOST.laravel.cloud
DB_PORT=5432
DB_DATABASE=sist
DB_USERNAME=ISI_DB_USER
DB_PASSWORD=ISI_DB_PASSWORD

# ────────────────────────────────────────────
# 4. SESSION & CACHE
# ────────────────────────────────────────────
# TIPS: Untuk production, gunakan "database" atau "redis"
# Jangan gunakan "file" karena Laravel Cloud ephemeral
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

QUEUE_CONNECTION=database

# ────────────────────────────────────────────
# 5. FILE STORAGE — S3 (WAJIB untuk production)
# ────────────────────────────────────────────
# CARA MENDAPATKAN (AWS S3):
#   1. Login https://aws.amazon.com → IAM → Users → Create user
#   2. Attach policy: AmazonS3FullAccess
#   3. Security credentials → Create access key
#   4. Copy Access Key ID dan Secret Access Key
#   5. Buka S3 → Create bucket → nama: sist-production
#   6. Region: pilih ap-southeast-1 (Singapore) terdekat
#
# CARA MENDAPATKAN (DigitalOcean Spaces):
#   1. Login https://cloud.digitalocean.com → Spaces
#   2. Create Spaces Bucket → nama: sist-production
#   3. Region: Singapore (SGP1)
#   4. API → Spaces Access Keys → Generate New Key
#   5. Copy Key dan Secret
#   6. Endpoint: https://sgp1.digitaloceanspaces.com
#
# CARA MENDAPATKAN (Cloudflare R2):
#   1. Login https://dash.cloudflare.com → R2
#   2. Create bucket → nama: sist-production
#   3. Manage R2 API Tokens → Create API Token
#   4. Copy Access Key ID dan Secret Access Key
#   5. Endpoint: copy dari R2 dashboard (contoh: https://xxx.r2.cloudflarestorage.com)

FILESYSTEM_DISK=s3
MEDIA_DISK=s3

AWS_ACCESS_KEY_ID=ISI_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=ISI_SECRET_KEY
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=sist-production
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Catatan untuk DigitalOcean Spaces:
# AWS_ENDPOINT=https://sgp1.digitaloceanspaces.com
# AWS_USE_PATH_STYLE_ENDPOINT=false

# Catatan untuk Cloudflare R2:
# AWS_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# AWS_USE_PATH_STYLE_ENDPOINT=true

# ────────────────────────────────────────────
# 6. MAIL / EMAIL (Opsional tapi direkomendasikan)
# ────────────────────────────────────────────
# CARA MENDAPATKAN (Mailgun — Recommended):
#   1. Daftar https://www.mailgun.com
#   2. Verify domain Anda (sekolah.sch.id)
#   3. Settings → API Keys → copy API Key
#   4. Domain Settings → SMTP → copy credentials
#
# CARA MENDAPATKAN (Gmail):
#   1. Google Account → Security → 2-Step Verification (aktifkan)
#   2. App passwords → Generate → pilih "Mail"
#   3. Copy password yang muncul (16 karakter)
#   4. Gunakan Gmail address sebagai username
#
# CARA MENDAPATKAN (Mailtrap — untuk testing):
#   1. Daftar https://mailtrap.io
#   2. Inbox → Demo inbox → copy SMTP credentials

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=ISI_MAIL_USERNAME
MAIL_PASSWORD=ISI_MAIL_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@ISI_DOMAIN.sch.id
MAIL_FROM_NAME="${APP_NAME}"

# ────────────────────────────────────────────
# 7. SCHOOL CONFIG (Opsional — override identitas sekolah)
# ────────────────────────────────────────────
# Jika kosong, akan pakai default dari config/sekolah.php
# Ganti sesuai identitas sekolah Anda

SEKOLAH_NAMA="ISI_NAMA_SEKOLAH"
SEKOLAH_NAMA_PENDEK="ISI_NAMA_PENDEK"
SEKOLAH_TAGLINE="ISI_TAGLINE"
SEKOLAH_NPSN=ISI_NPSN
SEKOLAH_AKREDITASI=A
SEKOLAH_TAHUN_BERDIRI=ISI_TAHUN
SEKOLAH_KEPALA="ISI_KEPALA_SEKOLAH"
SEKOLAH_TELP="ISI_TELEPON"
SEKOLAH_EMAIL=ISI_EMAIL_SEKOLAH

# ────────────────────────────────────────────
# 8. PPDB CONFIG (Opsional)
# ────────────────────────────────────────────
PPDB_DIBUKA=true
PPDB_MULAI=2026-05-01
PPDB_SELESAI=2026-06-30
PPDB_KUOTA=100

# ────────────────────────────────────────────
# 9. LAINNYA (Biarkan default)
# ────────────────────────────────────────────
BROADCAST_CONNECTION=log
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error
BCRYPT_ROUNDS=12
VITE_APP_NAME="${APP_NAME}"
