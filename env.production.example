# ============================================
# SIST — Environment Variables untuk Laravel Cloud
# ============================================
# Data sudah diisi, TAPI ada yang perlu diperbaiki (lihat komentar)
# ============================================

# ────────────────────────────────────────────
# APP (OK — Sudah benar)
# ────────────────────────────────────────────
APP_NAME=web-sekolah
APP_ENV=production
APP_DEBUG=false
APP_URL=https://web-sekolah-main-zcmbgd.free.laravel.cloud

# ⚠️ PERHATIAN: APP_KEY di bawah ini adalah CONTOH!
# ANDA HARUS generate sendiri di lokal:
#   php artisan key:generate --show
# Lalu ganti dengan key hasil generate Anda sendiri
APP_KEY=base64:nh2X3D58LNYNr0wWivrx4YFpFLZkVdYgZsaMp9aN5T8=

# ────────────────────────────────────────────
# LOCALE & TIMEZONE (OK)
# ────────────────────────────────────────────
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

# ────────────────────────────────────────────
# LOG (Biarkan default — HAPUS yang tidak perlu)
# ────────────────────────────────────────────
# ❌ HAPUS baris ini:
# LOG_CHANNEL=laravel-cloud-socket
# LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter
#
# ✅ Ganti dengan:
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ────────────────────────────────────────────
# SESSION (⚠️ GANTI ke database untuk production)
# ────────────────────────────────────────────
# ❌ Jangan pakai cookie untuk production:
# SESSION_DRIVER=cookie
#
# ✅ Gunakan database agar aman di multiple server:
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ────────────────────────────────────────────
# VITE (OK)
# ────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ────────────────────────────────────────────
# DATABASE (⚠️ HOST MASIH CONTOH — HARUS DIGANTI!)
# ────────────────────────────────────────────
# ❌ HOST di bawah ini masih contoh. Dari mana:
#    1. Laravel Cloud dashboard → Databases
#    2. Copy connection string yang asli
#    3. Jangan pakai db-abc123 (itu cuma contoh)

DB_CONNECTION=pgsql
DB_HOST=db-abc123.laravel.cloud          # ⚠️ GANTI INI!
DB_PORT=5432
DB_DATABASE=sist
DB_USERNAME=sist_user                    # ⚠️ GANTI INI!
DB_PASSWORD=Rahasia25++                  # ⚠️ GANTI INI!

# ────────────────────────────────────────────
# CACHE & QUEUE (OK)
# ────────────────────────────────────────────
CACHE_STORE=database
CACHE_PREFIX=

QUEUE_CONNECTION=database

# ────────────────────────────────────────────
# FILE STORAGE — S3 (⚠️ KEY MASIH CONTOH!)
# ────────────────────────────────────────────
# ❌ KEY di bawah ini adalah CONTOH dari AWS Documentation!
#    ANDA HARUS ganti dengan key asli dari:
#    - AWS S3 IAM User Access Key, ATAU
#    - DigitalOcean Spaces Access Key, ATAU
#    - Cloudflare R2 API Token
#
#    Kalau belum punya S3, biarkan pakai local dulu:
#    FILESYSTEM_DISK=local
#    MEDIA_DISK=public

FILESYSTEM_DISK=s3
MEDIA_DISK=s3

AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE        # ⚠️ GANTI INI!
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY  # ⚠️ GANTI INI!
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=sist-production
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ────────────────────────────────────────────
# MAIL / EMAIL (⚠️ PERLU APP PASSWORD untuk Gmail)
# ────────────────────────────────────────────
# ⚠️ KALAU pakai Gmail:
#    1. Aktifkan 2-Step Verification di Google Account
#    2. Google Account → Security → App passwords
#    3. Generate → pilih "Mail"
#    4. Copy 16-digit password yang muncul
#    5. PASSWORD di bawah harus diganti dengan app password!
#
# ⚠️ Jangan pakai password login Gmail biasa (itu tidak akan berfungsi)

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=penelitian.mitra@gmail.com
MAIL_PASSWORD=Rahasia25++          # ⚠️ HARUS diganti dengan Gmail App Password!
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=penelitian.mitra@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# ────────────────────────────────────────────
# SCHOOL CONFIG (Opsional — ganti sesuai sekolah)
# ────────────────────────────────────────────
SEKOLAH_NAMA="SD Negeri Contoh 01 Jakarta"
SEKOLAH_NAMA_PENDEK="SDN CONTOH 01"
SEKOLAH_TAGLINE="Unggul, Mandiri, Berprestasi"
SEKOLAH_NPSN=20101234
SEKOLAH_AKREDITASI=A
SEKOLAH_TAHUN_BERDIRI=1985
SEKOLAH_KEPALA="Bapak Ahmad Syahid, S.Pd., M.Pd."
SEKOLAH_TELP="(021) 1234-5678"
SEKOLAH_EMAIL=penelitian.mitra@gmail.com

# ────────────────────────────────────────────
# PPDB CONFIG (OK)
# ────────────────────────────────────────────
PPDB_DIBUKA=true
PPDB_MULAI=2026-05-01
PPDB_SELESAI=2026-06-30
PPDB_KUOTA=100

# ────────────────────────────────────────────
# MAINTENANCE & LAINNYA (OK)
# ────────────────────────────────────────────
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BROADCAST_CONNECTION=log
BCRYPT_ROUNDS=12
