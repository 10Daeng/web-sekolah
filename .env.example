APP_NAME=SIST
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost

# School config overrides
SEKOLAH_NAMA="SD Negeri Contoh 01 Jakarta"
SEKOLAH_NAMA_PENDEK="SDN CONTOH 01"
SEKOLAH_TAHUN_BERDIRI=1985
SEKOLAH_KEPALA="Bapak Ahmad Syahid, S.Pd., M.Pd."

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# DATABASE - Pilihan: sqlite (local dev) | pgsql (production/Laravel Cloud) | mysql
# ============================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=sist
DB_USERNAME=root
DB_PASSWORD=

# For local development with SQLite (uncomment below, comment above):
# DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=database/database.sqlite
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# FILE STORAGE - Local (dev) | S3 / DO Spaces / Cloudflare R2 (production)
# ============================================
FILESYSTEM_DISK=local
# FILESYSTEM_DISK=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=sist-uploads
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=

# Media Library disk: public (local) | s3 (cloud production)
MEDIA_DISK=public

# DigitalOcean Spaces / Cloudflare R2 (alternative to AWS S3):
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=sist-bucket
# AWS_ENDPOINT=https://s3.ap-southeast-1.digitaloceanspaces.com
# AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
