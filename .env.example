# ============================================
# SIST — Environment Variables Template
# ============================================
# Copy file ini ke .env dan sesuaikan value-nya
# Untuk production/Laravel Cloud: gunakan .env.production sebagai referensi

# ────────────────────────────────────────────
# APP
# ────────────────────────────────────────────
APP_NAME=SIST
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# Generate via: php artisan key:generate
APP_KEY=

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

# ────────────────────────────────────────────
# SCHOOL CONFIG
# ────────────────────────────────────────────
SEKOLAH_NAMA="SD Negeri Contoh 01 Jakarta"
SEKOLAH_NAMA_PENDEK="SDN CONTOH 01"
SEKOLAH_TAGLINE="Unggul, Mandiri, Berprestasi"
SEKOLAH_NPSN=20101234
SEKOLAH_AKREDITASI=A
SEKOLAH_TAHUN_BERDIRI=1985
SEKOLAH_KEPALA="Bapak Ahmad Syahid, S.Pd., M.Pd."
SEKOLAH_TELP="(021) 1234-5678"
SEKOLAH_EMAIL=info@sdncontoh01.sch.id

# ────────────────────────────────────────────
# DATABASE — Pilihan: sqlite (dev) | pgsql (production)
# ────────────────────────────────────────────
# Local Development (SQLite):
DB_CONNECTION=sqlite

# Production (PostgreSQL):
# DB_CONNECTION=pgsql
# DB_HOST=your-db-host
# DB_PORT=5432
# DB_DATABASE=sist
# DB_USERNAME=your-user
# DB_PASSWORD=your-password

# ────────────────────────────────────────────
# SESSION & CACHE
# ────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log

# ────────────────────────────────────────────
# FILE STORAGE — local (dev) | s3 (production)
# ────────────────────────────────────────────
FILESYSTEM_DISK=local
MEDIA_DISK=public

# AWS S3 / DO Spaces / Cloudflare R2 (production):
# FILESYSTEM_DISK=s3
# MEDIA_DISK=s3
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=sist-bucket
# AWS_ENDPOINT=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ────────────────────────────────────────────
# MAIL
# ────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ────────────────────────────────────────────
# PPDB
# ────────────────────────────────────────────
PPDB_DIBUKA=true
PPDB_MULAI=2026-05-01
PPDB_SELESAI=2026-06-30
PPDB_KUOTA=100

# ────────────────────────────────────────────
# MAINTENANCE & LOG
# ────────────────────────────────────────────
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

BCRYPT_ROUNDS=12

# ────────────────────────────────────────────
# VITE (Frontend Build)
# ────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
